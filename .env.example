# ============================================================
# Sol Monitor — Environment Configuration
# ============================================================

# ── BirdEye API（必填）
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Helius API（预留）
HELIUS_API_KEY=your_helius_api_key_here

# ── 本服务监听端口
PORT=3003

# ── 交易机器人 Webhook
TRADE_BOT_HOST=localhost
TRADE_BOT_PORT=3002

# ── 代币监控参数
TOKEN_MAX_AGE_MINUTES=30

# ── REST 轮询间隔（毫秒）：策略驱动频率
# 建议范围：5000（激进）~ 15000（保守）
# 注意：每个代币每次轮询消耗 1 次 BirdEye API 请求
REST_POLL_INTERVAL_MS=10000

# ── 白名单退出条件
FDV_MINIMUM=10000

# ── 止盈止损（百分比）
TP_PCT=150
SL_PCT=50
